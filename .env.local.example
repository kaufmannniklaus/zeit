# Datenbank – PostgreSQL auf eigenem Server
DATABASE_URL=postgresql://BENUTZER:PASSWORT@db.geld-herr.com:5432/DATENBANKNAME

# Session-Sicherheit (mind. 32 zufällige Zeichen)
SESSION_SECRET=MINDESTENS_32_ZEICHEN_ZUFALLSSTRING_HIER_EINTRAGEN

# Login-Zugangsdaten (Passwort als bcrypt-Hash speichern)
# Hash erzeugen: node -e "const b=require('bcryptjs');b.hash('DEIN_PASSWORT',10).then(console.log)"
APP_USERNAME=dein_benutzername
APP_PASSWORD_HASH=$2b$10$BEISPIEL_HASH_HIER_EINTRAGEN
