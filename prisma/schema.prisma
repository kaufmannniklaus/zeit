generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum AbsenzTyp {
  FERIEN
  KRANK
  FEIERTAG
  SONSTIGES
}

model Zeiteintrag {
  id           String   @id @default(cuid())
  datum        DateTime @db.Date
  startzeit    DateTime @db.Time(0)
  endzeit      DateTime @db.Time(0)
  pauseDauer   Int
  effektivzeit Int
  notiz        String?
  erstelltAm   DateTime @default(now())
  aktualisiertAm DateTime @updatedAt

  @@index([datum])
  @@index([erstelltAm])
}

model Absenz {
  id           String    @id @default(cuid())
  datum        DateTime  @db.Date
  typ          AbsenzTyp
  bezeichnung  String?
  erstelltAm   DateTime  @default(now())
  aktualisiertAm DateTime @updatedAt

  @@index([datum])
  @@index([typ])
}

model Einstellung {
  id                       String   @id @default("singleton")
  sollstundenProWoche      Float    @default(42.0)
  ueberstundenSaldoMinuten Int      @default(0)
  aktualisiertAm           DateTime @updatedAt
}

model TagessitzungDraft {
  id             String    @id @default(cuid())
  datum          DateTime  @unique @db.Date
  startzeit      String
  endzeit        String?
  pausen         Json      @default("[]")
  abgeschlossen  Boolean   @default(false)
  gesendeteNot   Json      @default("[]")
  naechsteNotAt  DateTime?
  naechsteNotTyp String?
  erstelltAm     DateTime  @default(now())
  aktualisiertAm DateTime  @updatedAt

  @@index([datum])
  @@index([naechsteNotAt])
}

model PausenProtokoll {
  id                String   @id @default(cuid())
  datum             DateTime @db.Date
  erfassteMinuten   Int
  effektiveMinuten  Int
  zeitNachgeholt    Boolean?
  erstelltAm        DateTime @default(now())

  @@index([datum])
}

model PushSubscription {
  id         String   @id @default(cuid())
  endpoint   String   @unique
  p256dh     String
  auth       String
  erstelltAm DateTime @default(now())
}
